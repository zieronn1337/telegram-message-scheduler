# Copy names to Vercel Project -> Settings -> Environment Variables.
# Never commit real values.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
SECRET_KEY=generate-a-unique-random-value
TOKEN_ENCRYPTION_KEY=generate-with-Fernet-generate-key
CRON_SECRET=generate-another-unique-random-value
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=replace-with-a-strong-password
DEFAULT_TIMEZONE=Asia/Baku
MAX_UPLOAD_MB=4
